+# Copyright 2024 Google. This software is provided as-is, without warranty or representation for any use or purpose. Your use of it is subject to your agreement with Google.
+
+import json
+import logging
+import re
+import datetime
+from typing import Optional, Dict, Any, List
+from google.cloud import discoveryengine_v1 as discoveryengine
+from ..core.base import BaseDocumentTransformer
+from ..core.models import RawPayload, PipelineContext
+
+logger = logging.getLogger("connector.bigquery.transformers")
+
+class DateTimeEncoder(json.JSONEncoder):
+    def default(self, obj):
+        if isinstance(obj, (datetime.datetime, datetime.date)):
+            return obj.isoformat()
+        return super().default(obj)
+
+def _json_dumps(obj: Any) -> str:
+    return json.dumps(obj, cls=DateTimeEncoder)
+
+def _convert_datetimes(obj: Any) -> Any:
+    if isinstance(obj, (datetime.datetime, datetime.date)):
+        return obj.isoformat()
+    if isinstance(obj, dict):
+        return {k: _convert_datetimes(v) for k, v in obj.items()}
+    if isinstance(obj, list):
+        return [_convert_datetimes(i) for i in obj]
+    return obj
+
+def _sanitize_doc_id(doc_id: str) -> str:
+    """Sanitizes document IDs to strictly conform to Discovery Engine constraints: ^[a-zA-Z0-9-_]+$"""
+    return re.sub(r'[^a-zA-Z0-9-_]', '_', str(doc_id))
+
+class SnoogutsTransformer(BaseDocumentTransformer):
+    """
+    Transforms Snooguts Mission Control raw payloads into Discovery Engine Documents.
+    Follows the schema defined in sync_schema.txt.
+    """
+    def __init__(self, datasource: str = "snoogutsmissioncontrol"):
+        self.datasource = datasource
+
+    def transform(self, data: RawPayload, context: PipelineContext) -> Optional[discoveryengine.Document]:
+        payload = _convert_datetimes(data.data)
+        if not isinstance(payload, dict):
+            return None
+        
+        entity_type = payload.get("entityType")
+        if not entity_type:
+            return None
+            
+        action = payload.get("action", "upsert")
+        if action == "delete":
+            # Pipeline currently handles upserts; deletes are handled via separate sync path.
+            return None
+
+        if entity_type == "initiative":
+            return self._transform_initiative(payload)
+        elif entity_type == "commitment":
+            return self._transform_commitment(payload)
+        elif entity_type == "launch":
+            return self._transform_launch(payload)
+        elif entity_type == "person":
+            return self._transform_person(payload)
+            
+        return None
+
+    def _build_acl_info(self, payload: Dict[str, Any]) -> Optional[discoveryengine.Document.AclInfo]:
+        is_private = payload.get("private", False)
+        allowed_users = payload.get("allowedUsers", [])
+        
+        if not is_private:
+            return discoveryengine.Document.AclInfo(
+                readers=[discoveryengine.Document.AclInfo.AccessRestriction(idp_wide=True)]
+            )
+        
+        principals = []
+        for email in allowed_users:
+            principal = discoveryengine.Principal(user_id=email)
+            principals.append(principal)
+            
+        if not principals:
+            # If private but no allowed users, it's effectively restricted to owner or nothing.
+            # Discovery Engine needs at least one principal or idp_wide.
+            # We might want to add the ownerEmail here.
+            owner = payload.get("ownerEmail")
+            if owner:
+                principals.append(discoveryengine.Principal(user_id=owner))
+            else:
+                return None
+                
+        return discoveryengine.Document.AclInfo(
+            readers=[discoveryengine.Document.AclInfo.AccessRestriction(principals=principals)]
+        )
+
+    def _transform_initiative(self, payload: Dict[str, Any]) -> discoveryengine.Document:
+        program_id = payload.get("id")
+        doc_id = f"initiative-{program_id}"
+        
+        struct_data = {
+            "datasource": self.datasource,
+            "objectType": "Initiatives",
+            "id": doc_id,
+            "title": payload.get("title", ""),
+            "viewURL": payload.get("url", f"https://launch.snooguts.net/programs/{program_id}"),
+            "createdAt": payload.get("createdAt"),
+            "updatedAt": payload.get("updatedAt"),
+            "author": {"email": payload.get("ownerEmail", "mission.control.internal.user@reddit.com")},
+        }
+        
+        custom_props = []
+        prop_map = {
+            "startDate": "startDate",
+            "endDate": "endDate",
+            "programStatus": "programStatus",
+            "primaryPillar": "primaryPillar",
+            "activeQuarters": "activeQuarters",
+            "linkedLaunchIds": "linkedLaunchIds",
+            "linkedCommitmentIds": "linkedCommitmentIds",
+        }
+        json_map = {
+            "hierarchyTeam": "hierarchyTeam",
+            "statusLogs": "statusLogsJSONString",
+            "links": "linksJSONString",
+            "decisions": "decisionsJSONString",
+            "risks": "risksJsonString",
+            "resources": "resourcesJsonString",
+        }
+        
+        for src, target in prop_map.items():
+            val = payload.get(src)
+            if val is not None:
+                custom_props.append({"name": target, "value": val})
+        for src, target in json_map.items():
+            val = payload.get(src)
+            if val is not None:
+                custom_props.append({"name": target, "value": _json_dumps(val)})
+                
+        struct_data["customProperties"] = custom_props
+        if "interactions" in payload:
+            struct_data["interactions"] = payload["interactions"]
+            
+        return discoveryengine.Document(
+            id=_sanitize_doc_id(doc_id),
+            struct_data=struct_data,
+            content=discoveryengine.Document.Content(
+                mime_type="text/plain",
+                raw_bytes=payload.get("description", "").encode("utf-8")
+            ),
+            acl_info=self._build_acl_info(payload)
+        )
+
+    def _transform_commitment(self, payload: Dict[str, Any]) -> discoveryengine.Document:
+        sc_id = payload.get("id")
+        doc_id = f"commitment-{sc_id}"
+        
+        struct_data = {
+            "datasource": self.datasource,
+            "objectType": "Commitments",
+            "id": doc_id,
+            "title": payload.get("title", ""),
+            "viewURL": payload.get("url", f"https://launch.snooguts.net/commitment/{sc_id}"),
+            "createdAt": payload.get("createdAt"),
+            "updatedAt": payload.get("updatedAt"),
+            "author": {"email": payload.get("ownerEmail", "mission.control.internal.user@reddit.com")},
+        }
+        
+        custom_props = []
+        prop_map = {
+            "responsibleUser": "responsibleUser",
+            "accountableUser": "accountableUser",
+            "quarter": "quarter",
+            "pillar": "pillar",
+            "commitmentStatus": "commitmentStatus",
+            "isClosedOut": "isClosedOut",
+        }
+        if "isClosedOut" in payload:
+            payload["isClosedOut"] = str(payload["isClosedOut"])
+            
+        for src, target in prop_map.items():
+            val = payload.get(src)
+            if val is not None:
+                custom_props.append({"name": target, "value": val})
+                
+        if "statusHistory" in payload:
+            custom_props.append({"name": "statusHistoryJsonString", "value": _json_dumps(payload["statusHistory"])})
+            
+        struct_data["customProperties"] = custom_props
+        if "interactions" in payload:
+            struct_data["interactions"] = payload["interactions"]
+            
+        return discoveryengine.Document(
+            id=_sanitize_doc_id(doc_id),
+            struct_data=struct_data,
+            content=discoveryengine.Document.Content(
+                mime_type="text/plain",
+                raw_bytes=payload.get("description", "").encode("utf-8")
+            ),
+            acl_info=self._build_acl_info(payload)
+        )
+
+    def _transform_launch(self, payload: Dict[str, Any]) -> discoveryengine.Document:
+        l_id = payload.get("id")
+        doc_id = f"launch-{l_id}"
+        
+        struct_data = {
+            "datasource": self.datasource,
+            "objectType": "Launches",
+            "id": doc_id,
+            "title": payload.get("title", ""),
+            "viewURL": payload.get("url", f"https://launch.snooguts.net/launch/{l_id}"),
+            "createdAt": payload.get("createdAt"),
+            "updatedAt": payload.get("updatedAt"),
+            "author": {"email": payload.get("ownerEmail", "mission.control.internal.user@reddit.com")},
+        }
+        
+        custom_props = []
+        prop_map = {
+            "launchDate": "launchDate",
+            "committedQuarter": "committedQuarter",
+            "platforms": "platforms",
+            "productSurfaces": "productSurfaces",
+            "pillars": "pillars",
+        }
+        for src, target in prop_map.items():
+            val = payload.get(src)
+            if val is not None:
+                custom_props.append({"name": target, "value": val})
+                
+        if "reviews" in payload:
+            custom_props.append({"name": "reviewsJsonString", "value": _json_dumps(payload["reviews"])})
+        if "commitmentIds" in payload:
+            custom_props.append({"name": "commitmentID", "value": _json_dumps([f"commitment-{cid}" for cid in payload["commitmentIds"]])})
+        if "links" in payload:
+            custom_props.append({"name": "links", "value": [_json_dumps(link) for link in payload["links"]]})
+        if "statusLogs" in payload:
+            custom_props.append({"name": "statusLogsJsonString", "value": _json_dumps(payload["statusLogs"])})
+            
+        struct_data["customProperties"] = custom_props
+        if "interactions" in payload:
+            struct_data["interactions"] = payload["interactions"]
+            
+        return discoveryengine.Document(
+            id=_sanitize_doc_id(doc_id),
+            struct_data=struct_data,
+            content=discoveryengine.Document.Content(
+                mime_type="text/plain",
+                raw_bytes=payload.get("description", "").encode("utf-8")
+            ),
+            acl_info=self._build_acl_info(payload)
+        )
+
+    def _transform_person(self, payload: Dict[str, Any]) -> discoveryengine.Document:
+        p_id = payload.get("id")
+        doc_id = f"person-{p_id}"
+        
+        struct_data = {
+            "datasource": self.datasource,
+            "objectType": "OrgData",
+            "id": doc_id,
+            "title": payload.get("title", ""), # title is email in mock
+            "viewURL": payload.get("url", f"https://launch.snooguts.net/org?u={payload.get('employeeId')}"),
+            "createdAt": payload.get("createdAt"),
+            "updatedAt": payload.get("updatedAt"),
+            "author": {"email": payload.get("email")},
+        }
+        
+        custom_props = []
+        prop_map = {
+            "managerEmail": "managerEmail",
+            "directorEmail": "directorEmail",
+            "executiveEmail": "executiveEmail",
+            "function": "function",
+            "specialties": "specialties",
+            "pillar": "pillar",
+            "email": "email",
+            "displayName": "displayName",
+            "positionId": "positionId",
+            "positionStatus": "positionStatus",
+            "employeeId": "employeeId",
+            "level": "level",
+            "hierarchyTeam": "hierarchyTeam",
+            "assignedToTeam": "assignedToTeam",
+        }
+        for src, target in prop_map.items():
+            val = payload.get(src)
+            if val is not None:
+                custom_props.append({"name": target, "value": val})
+                
+        struct_data["customProperties"] = custom_props
+        if "interactions" in payload:
+            struct_data["interactions"] = payload["interactions"]
+            
+        # OrgData usually allows anonymous access according to sync_schema.txt
+        return discoveryengine.Document(
+            id=_sanitize_doc_id(doc_id),
+            struct_data=struct_data,
+            content=discoveryengine.Document.Content(
+                mime_type="text/plain",
+                raw_bytes=payload.get("description", "").encode("utf-8")
+            ),
+            acl_info=discoveryengine.Document.AclInfo(
+                readers=[discoveryengine.Document.AclInfo.AccessRestriction(idp_wide=True)]
+            )
+        )
